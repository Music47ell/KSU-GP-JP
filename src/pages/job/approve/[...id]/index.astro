---
import { supabase } from "../../../../lib/supabase";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import Header from "../../../../components/admin/Header.astro";

const { cookies, redirect } = Astro;
const { id } = Astro.params;

const accessToken = cookies.get("sb-access-token");
const refreshToken = cookies.get("sb-refresh-token");
if (!accessToken || !refreshToken) { return redirect("/"); }

const { error } = await supabase.auth.setSession({
	refresh_token: refreshToken.value,
	access_token: accessToken.value,
});
if (error) {
	cookies.delete("sb-access-token", { path: "/" });
	cookies.delete("sb-refresh-token", { path: "/" });
	return redirect("/");
}

const { data: jobs } = await supabase
	.from("job_listings")
	.select("id, title, approved")
	.eq("id", id)
	.single();

const jobId = jobs?.id ?? "";
const jobName = jobs?.title ?? "";
---

<BaseLayout>
	<Header title="Approve Job Listing" />
	<main class="flex-1 flex items-center justify-center px-4 py-12">
		<div class="w-full max-w-md">
			<div class="text-center mb-8">
				<img src="/businessman.png" alt="Logo" class="w-16 h-16 mx-auto mb-4" />
				<h1 class="text-2xl font-bold text-gray-900">Review Job Listing</h1>
			</div>
			<div class="bg-white rounded-xl shadow-sm ring-1 ring-gray-200 p-8">
				<form action="/api/job/approve" method="POST" class="space-y-5">
					<input type="hidden" name="job_id" value={jobId} />
					<div>
						<label class="block text-sm font-medium text-gray-700 mb-1">Job Title</label>
						<input type="text" value={jobName} disabled readonly
							class="block w-full rounded-lg border border-gray-200 bg-gray-50 px-4 py-2.5 text-sm text-gray-500 cursor-not-allowed" />
					</div>
					<div>
						<label for="approved" class="block text-sm font-medium text-gray-700 mb-1">Decision</label>
						<select name="approved" id="approved"
							class="block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-colors">
							<option value="APPROVED">Approve</option>
							<option value="DENIED">Deny</option>
						</select>
					</div>
					<button type="submit"
						class="w-full inline-flex items-center justify-center rounded-lg bg-primary-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500/20 transition-colors">
						Submit Decision
					</button>
					<a href="/admin/dashboard"
						class="w-full inline-flex items-center justify-center rounded-lg bg-white px-4 py-2.5 text-sm font-semibold text-gray-700 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50 transition-colors">
						Back to Dashboard
					</a>
				</form>
			</div>
		</div>
	</main>
</BaseLayout>
