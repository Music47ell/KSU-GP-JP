---
import { supabase } from "../../../../../lib/supabase";
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import Header from "../../../../../components/seeker/Header.astro";

const { cookies, params, redirect } = Astro;

const accessToken = cookies.get("sb-access-token");
const refreshToken = cookies.get("sb-refresh-token");

if (!accessToken || !refreshToken) { return redirect("/"); }

const { data, error } = await supabase.auth.setSession({
	refresh_token: refreshToken.value,
	access_token: accessToken.value,
});

if (error) {
	cookies.delete("sb-access-token", { path: "/" });
	cookies.delete("sb-refresh-token", { path: "/" });
	return redirect("/");
}

const { data: seeker } = await supabase
	.from("seeker")
	.select("*")
	.eq("user_id", params.id)
	.single();

interface SeekerProfile {
	user_id: string; name: string; resume_url: string;
	github_url: string; linkedin_url: string; portfolio_url: string;
}

const profile: SeekerProfile = seeker as SeekerProfile;
const userName: string = profile?.name ?? "";
const resumeUrl: string = profile?.resume_url ?? "";
const githubUrl: string = profile?.github_url ?? "";
const linkedinUrl: string = profile?.linkedin_url ?? "";
const portfolioUrl: string = profile?.portfolio_url ?? "";
---

<BaseLayout>
	<div class="flex-1">
		<Header title="Seeker Profile" userId={data?.user?.id} />
		<main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
			<div class="bg-white rounded-xl shadow-sm ring-1 ring-gray-200 overflow-hidden">
				<div class="px-6 py-5 border-b border-gray-200">
					<h2 class="text-lg font-semibold text-gray-900">Profile Overview</h2>
				</div>
				<dl class="divide-y divide-gray-200">
					<div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4 bg-gray-50/50">
						<dt class="text-sm font-medium text-gray-500">Name</dt>
						<dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">{userName || "—"}</dd>
					</div>
					<div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
						<dt class="text-sm font-medium text-gray-500">Resume</dt>
						<dd class="mt-1 text-sm sm:mt-0 sm:col-span-2">
							{ resumeUrl
								? <a href={resumeUrl} target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700 font-medium">View Resume &rarr;</a>
								: <span class="text-gray-400">Not provided</span>
							}
						</dd>
					</div>
					<div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4 bg-gray-50/50">
						<dt class="text-sm font-medium text-gray-500">GitHub</dt>
						<dd class="mt-1 text-sm sm:mt-0 sm:col-span-2">
							{ githubUrl
								? <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700 font-medium">View GitHub &rarr;</a>
								: <span class="text-gray-400">Not provided</span>
							}
						</dd>
					</div>
					<div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
						<dt class="text-sm font-medium text-gray-500">LinkedIn</dt>
						<dd class="mt-1 text-sm sm:mt-0 sm:col-span-2">
							{ linkedinUrl
								? <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700 font-medium">View LinkedIn &rarr;</a>
								: <span class="text-gray-400">Not provided</span>
							}
						</dd>
					</div>
					<div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4 bg-gray-50/50">
						<dt class="text-sm font-medium text-gray-500">Portfolio</dt>
						<dd class="mt-1 text-sm sm:mt-0 sm:col-span-2">
							{ portfolioUrl
								? <a href={portfolioUrl} target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700 font-medium">View Portfolio &rarr;</a>
								: <span class="text-gray-400">Not provided</span>
							}
						</dd>
					</div>
				</dl>
			</div>
		</main>
	</div>
</BaseLayout>
